{
  "version": 2,
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "builds": [
    { "src": "api/**/*", "use": "@vercel/node" },
    { "src": "dist/client/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "dist/client/assets/$1" },
    { "src": "/(favicon\\.ico|logo192\\.png|logo512\\.png|manifest\\.json|robots\\.txt)", "dest": "dist/client/$1" },
    { "src": "/.*", "dest": "dist/client/index.html" }
  ]
}
