{
  "version": 2,
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "builds": [
    { "src": "dist/client/**/*", "use": "@vercel/static" },
    { "src": "api/**/*", "use": "@vercel/node@4.0.0" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
